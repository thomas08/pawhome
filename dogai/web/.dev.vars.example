# Cloudflare local dev environment variables
# Copy to .dev.vars (gitignored) แล้วใส่ค่าจริง
# ใช้โดย `wrangler pages dev` และ `next dev` (ผ่าน setupDevPlatform)
#
# Hyperdrive ใน local dev: wrangler จะ mock binding โดยใช้ DATABASE_URL โดยตรง
DATABASE_URL="postgresql://pawhome:password@localhost:5432/pawhome"

OPENCLAW_GATEWAY_TOKEN=""

R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="pawhome-photos"
R2_PUBLIC_URL="https://photos.pawhome.app"

NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_TELEGRAM_BOT_URL="https://t.me/PawHomeBot"
