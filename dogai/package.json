{
  "name": "pawhome",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx scripts/seed.ts",
    "dev": "npm run db:generate && npm -C web run dev",
    "build": "npm run db:generate && npm -C web run build",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "zod": "^3.24.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.700.0",
    "@prisma/client": "^6.19.3",
    "dotenv": "^16.4.0"
  }
}
